{
  "manifest_version": 3,
  "name": "LoopLock",
  "version": "0.1.0",
  "description": "Lock and loop a selected A-B playback range on YouTube and HTML5 media sites.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LoopLock",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
  {
    "matches": ["https://www.youtube.com/*", "https://*.youtube.com/*"],
    "js": ["content.js"],
    "css": ["assets/content.css"],
    "run_at": "document_idle"
  }
]
}